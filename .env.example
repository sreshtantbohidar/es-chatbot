# Elasticsearch Connection
ES_HOSTS=http://192.168.1.16:9200
ES_USERNAME=elastic
ES_PASSWORD=your_password_here

# LLM Backend (Ollama via OpenAI-compatible API)
LLM_BASE_URL=http://192.168.1.125:11434/v1
LLM_API_KEY=ollama

# App Settings
APP_HOST=0.0.0.0
APP_PORT=8000

# Note: LLM_MODEL is NOT hardcoded here.
# Model is selected via the UI dropdown at runtime.
# Make sure your Ollama server has at least one model pulled:
#   ollama pull llama3:8b-instruct-q8_0
